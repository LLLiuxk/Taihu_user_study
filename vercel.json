{
    "name": "taihu-user-study",
    "version": 2,
    "framework": null,
    "cleanUrls": true,
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/models/(.*)",
        "destination": "/models/$1"
      }
    ]
}
